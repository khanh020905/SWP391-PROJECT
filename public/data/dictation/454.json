{"lessonId":"454","lessonName":"[CONVERSATIONS] - 56. To Buy a Birthday Present","audioSrc":"","challenges":[{"id":18386,"position":1,"content":"What are you getting Jim for his birthday?","jsonContent":["What","are","you","getting","Jim","for","his","birthday?"],"solution":[["What"],["are"],["you"],["getting"],["Jim"],["for"],["his"],["birthday?"]],"audioSrc":"https://dailydictation.com/upload/english-conversations/56-to-buy-a-birthday-present-2022-03-07-21-23-22/1.mp3"},{"id":18387,"position":2,"content":"I don't know yet.","jsonContent":["I",["don't","do not"],"know","yet."],"solution":[["I"],["don't","do not"],["know"],["yet."]],"audioSrc":"https://dailydictation.com/upload/english-conversations/56-to-buy-a-birthday-present-2022-03-07-21-23-22/2.mp3"},{"id":18388,"position":3,"content":"You can always get him a shirt.","jsonContent":["You","can","always","get","him","a","shirt."],"solution":[["You"],["can"],["always"],["get"],["him"],["a"],["shirt."]],"audioSrc":"https://dailydictation.com/upload/english-conversations/56-to-buy-a-birthday-present-2022-03-07-21-23-22/3.mp3"},{"id":18389,"position":4,"content":"But I got him one last year.","jsonContent":["But","I","got","him",["one","1"],"last","year."],"solution":[["But"],["I"],["got"],["him"],["one","1"],["last"],["year."]],"audioSrc":"https://dailydictation.com/upload/english-conversations/56-to-buy-a-birthday-present-2022-03-07-21-23-22/4.mp3"},{"id":18390,"position":5,"content":"Oh, that's right. Let me think.","jsonContent":["Oh,",["that's","that is"],"right.","Let","me","think."],"solution":[["Oh,"],["that's","that is"],["right."],["Let"],["me"],["think."]],"audioSrc":"https://dailydictation.com/upload/english-conversations/56-to-buy-a-birthday-present-2022-03-07-21-23-22/5.mp3"},{"id":18391,"position":6,"content":"I want to get him something different.","jsonContent":["I","want","to","get","him","something","different."],"solution":[["I"],["want"],["to"],["get"],["him"],["something"],["different."]],"audi