{"lessonId":"421","lessonName":"[CONVERSATIONS] - 23. A Date (1)","audioSrc":"","challenges":[{"id":17972,"position":1,"content":"What are you so happy about? You're grinning from ear to ear.","jsonContent":["What","are","you","so","happy","about?",["You're","you are"],"grinning","from","ear","to","ear."],"solution":[["What"],["are"],["you"],["so"],["happy"],["about?"],["You're","you are"],["grinning"],["from"],["ear"],["to"],["ear."]],"audioSrc":"https://dailydictation.com/upload/english-conversations/23-a-date-1-2022-03-07-21-11-51/1.mp3"},{"id":17973,"position":2,"content":"Sandy and I are going to go out this weekend.","jsonContent":["Sandy","and","I","are","going","to","go","out","this","weekend."],"solution":[["Sandy"],["and"],["I"],["are"],["going"],["to"],["go"],["out"],["this"],["weekend."]],"audioSrc":"https://dailydictation.com/upload/english-conversations/23-a-date-1-2022-03-07-21-11-51/2.mp3"},{"id":17974,"position":3,"content":"Oh, yeah? That's fast work. That's great!","jsonContent":["Oh,","yeah?",["That's","that is"],"fast","work.",["That's","that is"],"great!"],"solution":[["Oh,"],["yeah?"],["That's","that is"],["fast"],["work."],["That's","that is"],["great!"]],"audioSrc":"https://dailydictation.com/upload/english-conversations/23-a-date-1-2022-03-07-21-11-51/3.mp3"},{"id":17975,"position":4,"content":"Which night are you going to see her, Friday or Saturday?","jsonContent":["Which","night","are","you","going","to","see","her,","Friday","or","Saturday?"],"solution":[["Which"],["night"],["are"],["you"],["going"],["to"],["see"],["her,"],["Friday"],["or"],["Saturday?"]],"audioSrc":"https://dailydictation.com/upload/english-conversations/23-a-date-1-2022-03-07-21-11-51/4.mp3"},{"id":17976,"position":5,"content":"On Friday. She isn't going to be in town on Saturday and Sunday.","jsonContent":["On","Friday.","She","isn't","going","to","be","in","town","on","Saturday","and","Sunday."],"solution":[["On"],["Friday."],["She"],["isn't"],["going"],["to"],["be"],["in"],["town"],["on"],["Saturday"],["and"],["Sunday."]],"audioSrc":"https://dailydictation.com/upload/english-conversations/23-a-date-1-2022-03-07-21-11-51/5.mp3"},{"id":17977,"position":6,"content":"She's going to visit a friend in Quebec.","jsonContent":["She's","going","to","visit","a","friend","in","Quebec."],"solution":[["She's"],["going"],["to"],["visit"],["a"],["friend"],["in"],["Quebec."]],"audioSrc":"https://dailydictation.com/upload/english-conversations/23-a-date-1-2022-03-07-21-11-51/6.mp3"},{"id":17978,"position":7,"content":"What are you going to do on Friday?","jsonContent":["What","are","you","going","to","do","on","Friday?"],"solution":[["What"],["are"],["you"],["going"],["to"],["do"],["on"],["Friday?"]],"audioSrc":"https://dailydictation.com/upload/english-conversations/23-a-date-1-2022-03-07-21-11-51/7.mp3"},{"id":17979,"position":8,"content":"I don't know yet. Do you have any ideas?","jsonContent":["I",["don't","do not"],"know","yet.","Do","you","have","any","ideas?"],"solution":[["I"],["don't","do not"],["know"],["yet."],["Do"],["you"],["have"],["any"],["ideas?"]],"audioSrc":"https://dailydictation.com/upload/english-conversations/23-a-date-1-2022-03-07-21-11-51/8.mp3"},{"id":17980,"position":9,"content":"How about taking her to a Chinese restaurant?","jsonContent":["How","about","taking","her","to","a","Chinese","restaurant?"],"solution":[["How"],["about"],["taking"],["her"],["to"],["a"],["Chinese"],["restaurant?"]],"audioSrc":"https://dailydictation.com/upload/english-conversations/23-a-date-1-2022-03-07-21-11-51/9.mp3"},{"id":17981,"position":10,"content":"I've heard that she likes Chinese food.","jsonContent":[["I've","I have"],"heard","that","she","likes","Chinese","food."],"solution":[["I've","I have"],["heard"],["that"],["she"],["likes"],["Chinese"],["food."]],"audioSrc":"https://dailydictation.com/upload/english-conversations/23-a-date-1-2022-03-07-21-11-51/10.mp3"},{"id":17982,"position":11,"content":"That's a great idea.","jsonConte