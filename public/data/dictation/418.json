{"lessonId":"418","lessonName":"[CONVERSATIONS] - 20. Phone Out of Order (2)","audioSrc":"","challenges":[{"id":17948,"position":1,"content":"Hey! What's the matter with the phone?","jsonContent":["Hey!",["What's","what is"],"the","matter","with","the","phone?"],"solution":[["Hey!"],["What's","what is"],["the"],["matter"],["with"],["the"],["phone?"]],"audioSrc":"https://dailydictation.com/upload/english-conversations/20-phone-out-of-order-2-2022-03-07-21-11-02/1.mp3"},{"id":17949,"position":2,"content":"Here, listen to this peculiar noise.","jsonContent":["Here,","listen","to","this","peculiar","noise."],"solution":[["Here,"],["listen"],["to"],["this"],["peculiar"],["noise."]],"audioSrc":"https://dailydictation.com/upload/english-conversations/20-phone-out-of-order-2-2022-03-07-21-11-02/2.mp3"},{"id":17950,"position":3,"content":"It doesn't sound like a dial tone.","jsonContent":["It",["doesn't","does not"],"sound","like","a","dial","tone."],"solution":[["It"],["doesn't","does not"],["sound"],["like"],["a"],["dial"],["tone."]],"audioSrc":"https://dailydictation.com/upload/english-conversations/20-phone-out-of-order-2-2022-03-07-21-11-02/3.mp3"},{"id":17951,"position":4,"content":"It must be out of order.","jsonContent":["It","must","be","out","of","order."],"solution":[["It"],["must"],["be"],["out"],["of"],["order."]],"audioSrc":"https://dailydictation.com/upload/english-conversations/20-phone-out-of-order-2-2022-03-07-21-11-02/4.mp3"},{"id":17952,"position":5,"content":"We'd better notify the phone company.","jsonContent":["We'd","better","notify","the","phone",["company.","Co"]],"solution":[["We'd"],["better"],["notify"],["the"],["phone"],["company.","Co"]],"audioSrc":"https://dailydictation.com/upload/english-conversations/20-phone-out-of-order-2-2022-03-07-21-11-02/5.mp3"},{"id":17953,"position":6,"content":"How do we do that? We can't use the phone.","jsonContent":["How","do","we","do","that?","We","can't","use","the","phone."],"solution":[["How"],["do"],["we"],["do"],["that?"],["We"],["can't"],["use"],["the"],["phone."]],"audioSrc":"https://dailydictation.com/upload/english-conversations/20-phone-out-of-order-2-2022-03-07-21-11-02/6.mp3"},{"id":17954,"position":7,"content":"Let's go next door and use our neighbour's phone.","jsonContent":["Let's","go","next","door","and","use","our",["neighbour's","neighbor's"],"phone."],"solution":[["Let's"],["go"],["next"],["door"],["and"],["use"],["our"],["neighbour's","neighbor's"],["phone."]],"audioSrc":"https://dailydictation.com/upload/english-conversations/20-phone-out-of-order-2-2022-03-07-21-11-02/7.mp3"},{"id":17955,"position":8,"content":"He's always complaining about people. I don't wanna ask any favours of him.","jsonContent":["He's","always","complaining","about","people.","I","don't",["wanna","want to"],"ask","any",["favours","favors"],"of","him."],"solution":[["He's"],["always"],["complaining"],["about"],["people."],["I"],["don't"],["wanna","want to"],["ask"],["any"],["favours","favors"],["of"],["him."]],"audioSrc":"https://dailydictation.com/upload/english-conversations/20-phone-out-of-order-2-2022-03-07-21-11-02/8.mp3"},{"id":17956,"position":9,"content":"How about across the street?","jsonContent":["How","about","across","the","street?"],"solution":[["How"],["about"],["across"],["the"],["street?"]],"audioSrc":"https://dailydictation.com/upload/english-conversations/20-phone-out-of-order-2-2022-03-07-21-11-02/9.mp3"},{"id":17957,"position":10,"content":"I forgot about Mrs. Riley! I'm sure she'd let us use her phone.","jsonContent":["I","forgot","about","Mrs.","Riley!",["I'm","I am"],"sure","she'd","let","us","use","her","phone."],"solution":[["I"],["forgot"],["about"],["Mrs."],["Riley!"],["I'm","I am"],["sure"],["she'd"],["let"],["us"],["use"],["her"],["phone."]],"audioSrc":"https://dailydictation.com/upload/english-conversations/20-phone-out-of-order-2-2022-03-07-21-11-02/10.mp3"}]}